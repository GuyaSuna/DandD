generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum UserRole {
  PLAYER
  DUNGEON_MASTER
  ADMIN
}

enum HealthLogType {
  DAMAGE
  HEAL
  SET
  TEMP
}

enum CombatStatus {
  ACTIVE
  FINISHED
  CANCELLED
}

enum CombatParticipantType {
  CHARACTER
  ENEMY
}

enum ItemType {
  WEAPON
  ARMOR
  POTION
  TOOL
  TREASURE
  DOCUMENT
  MAGIC
  OTHER
}

enum ItemRarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
}

model User {
  id        String     @id @default(cuid())
  name      String?
  email     String     @unique
  password  String?
  role      UserRole   @default(PLAYER)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  campaigns  Campaign[] @relation("CampaignDungeonMaster")
  characters Character[]
  healthLogs CharacterHealthLog[] @relation("HealthLogCreatedBy")
  dmNotes    CharacterDMNote[]    @relation("DMNoteCreatedBy")
  combats    Combat[]             @relation("CombatCreatedBy")
  inventoryItems InventoryItem[]   @relation("InventoryItemCreatedBy")
}

model Campaign {
  id              String      @id @default(cuid())
  name            String
  inviteCode      String      @unique
  description     String?     @db.Text
  dungeonMasterId String
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  dungeonMaster User        @relation("CampaignDungeonMaster", fields: [dungeonMasterId], references: [id], onDelete: Cascade)
  characters    Character[]
  healthLogs    CharacterHealthLog[]
  dmNotes       CharacterDMNote[]
  enemies       Enemy[]
  combats       Combat[]

  @@index([dungeonMasterId])
  @@index([inviteCode])
}

model Race {
  id          String     @id @default(cuid())
  name        String     @unique
  description String?    @db.Text
  speed       Int        @default(30)
  traits      Json?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  subraces   Subrace[]
  characters Character[]
}

model Subrace {
  id          String      @id @default(cuid())
  name        String
  description String?     @db.Text
  traits      Json?
  raceId      String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  race       Race        @relation(fields: [raceId], references: [id], onDelete: Cascade)
  characters Character[]

  @@unique([raceId, name])
  @@index([raceId])
}

model CharacterClass {
  id          String      @id @default(cuid())
  name        String      @unique
  description String?     @db.Text
  hitDie      Int
  primaryStat String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  characters Character[]
}

model Character {
  id          String   @id @default(cuid())
  name        String
  level       Int      @default(1)
  maxHp       Int
  currentHp   Int
  armorClass  Int      @default(10)
  attributes  Json
  backstory   String?  @db.Text
  traits      Json?
  inventory   Json?
  playerId    String
  campaignId  String?
  raceId      String
  subraceId   String?
  classId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  player    User           @relation(fields: [playerId], references: [id], onDelete: Cascade)
  campaign  Campaign?      @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  race      Race           @relation(fields: [raceId], references: [id])
  subrace   Subrace?       @relation(fields: [subraceId], references: [id])
  class     CharacterClass @relation(fields: [classId], references: [id])
  healthLogs CharacterHealthLog[]
  dmNotes    CharacterDMNote[]
  combatParticipants CombatParticipant[]
  inventoryItems InventoryItem[]

  @@index([playerId])
  @@index([campaignId])
  @@index([raceId])
  @@index([subraceId])
  @@index([classId])
}

model InventoryItem {
  id          String     @id @default(cuid())
  characterId String
  name        String
  description String?    @db.Text
  quantity    Int        @default(1)
  type        ItemType   @default(OTHER)
  rarity      ItemRarity @default(COMMON)
  isEquipped  Boolean    @default(false)
  weight      Float?
  value       Int?
  createdById String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  createdBy User?     @relation("InventoryItemCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([characterId])
  @@index([createdById])
  @@index([type])
  @@index([rarity])
}

model CharacterHealthLog {
  id          String        @id @default(cuid())
  characterId String
  campaignId  String?
  amount      Int
  previousHp  Int
  newHp       Int
  type        HealthLogType
  reason      String?       @db.Text
  createdById String?
  createdAt   DateTime      @default(now())

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  campaign  Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  createdBy User?     @relation("HealthLogCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([characterId])
  @@index([campaignId])
  @@index([createdById])
}

model CharacterDMNote {
  id          String   @id @default(cuid())
  characterId String
  campaignId  String
  title       String?
  content     String   @db.Text
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  campaign  Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  createdBy User      @relation("DMNoteCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([characterId])
  @@index([campaignId])
  @@index([createdById])
}

model Enemy {
  id           String   @id @default(cuid())
  campaignId   String
  name         String
  description  String?  @db.Text
  maxHp        Int
  currentHp    Int
  armorClass   Int
  strength     Int      @default(10)
  dexterity    Int      @default(10)
  constitution Int      @default(10)
  intelligence Int      @default(10)
  wisdom       Int      @default(10)
  charisma     Int      @default(10)
  attacks      Json?
  notes        String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  combatParticipants CombatParticipant[]

  @@index([campaignId])
}

model Combat {
  id               String       @id @default(cuid())
  campaignId       String
  name             String
  status           CombatStatus @default(ACTIVE)
  currentTurnIndex Int          @default(0)
  round            Int          @default(1)
  createdById      String
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  campaign     Campaign            @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  createdBy    User                @relation("CombatCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  participants CombatParticipant[]

  @@index([campaignId])
  @@index([createdById])
  @@index([status])
}

model CombatParticipant {
  id           String                @id @default(cuid())
  combatId     String
  characterId  String?
  enemyId      String?
  name         String
  type         CombatParticipantType
  initiative   Int
  turnOrder    Int
  maxHp        Int
  currentHp    Int
  armorClass   Int
  isDefeated   Boolean               @default(false)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  combat    Combat     @relation(fields: [combatId], references: [id], onDelete: Cascade)
  character Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)
  enemy     Enemy?     @relation(fields: [enemyId], references: [id], onDelete: SetNull)

  @@index([combatId])
  @@index([characterId])
  @@index([enemyId])
  @@index([turnOrder])
}
